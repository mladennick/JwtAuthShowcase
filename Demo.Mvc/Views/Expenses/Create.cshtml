@{
    ViewData["Title"] = "Add Expense";
}

<h1 class="h3 mb-3">Add Expense</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label" for="description">Description</label>
                <input class="form-control" id="description" name="description" required />
            </div>

            <div class="mb-3">
                <label class="form-label" for="amount">Amount</label>
                <input class="form-control" id="amount" name="amount" type="number" min="0.01" step="0.01" required />
            </div>

            <div class="mb-3">
                <label class="form-label" for="date">Date</label>
                <input class="form-control" id="date" name="date" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-controller="Expenses" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
