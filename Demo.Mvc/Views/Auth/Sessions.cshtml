@model IEnumerable<Demo.Mvc.Models.UserSession>
@{
    ViewData["Title"] = "Sessions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">User Sessions</h1>
    <a class="btn btn-outline-secondary" asp-action="Login">Back to Login</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>User</th>
                    <th>JWT Id</th>
                    <th>Created (UTC)</th>
                    <th>Expires (UTC)</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var session in Model)
            {
                var expired = session.ExpiresAtUtc <= DateTime.UtcNow;
                <tr>
                    <td>@session.AppUser?.Username</td>
                    <td><code>@session.JwtId</code></td>
                    <td>@session.CreatedAtUtc.ToString("u")</td>
                    <td>@session.ExpiresAtUtc.ToString("u")</td>
                    <td>
                        @if (session.IsRevoked)
                        {
                            <span class="badge bg-secondary">Revoked</span>
                        }
                        else if (expired)
                        {
                            <span class="badge bg-warning text-dark">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        @if (!session.IsRevoked)
                        {
                            <form asp-action="Revoke" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@session.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
